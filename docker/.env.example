# ==========================================================
# KCase 部署配置 (.env)
# 复制为 .env 后再启动: cp .env.example .env
# 启动前请按下方分区调整, 特别是【必改】部分
# ==========================================================


# ---------------- 【必改 1/1】数据库密码 ----------------
# 警告: MYSQL_PASSWORD 必须等于 MYSQL_ROOT_PASSWORD
# 当前 backend 用 root 账号登录 mysql, 二者不一致会导致启动失败
MYSQL_ROOT_PASSWORD=change_me
MYSQL_PASSWORD=change_me


# ---------------- 【可选】AI 生成能力 (OpenAI 兼容协议) ----------------
# 不填则 AI 生成功能不可用, 其他功能正常使用
AI_OPENAI_BASE_URL=
AI_OPENAI_API_KEY=
AI_OPENAI_MODEL_NAME=
AI_OPENAI_CHAT_COMPLETIONS_PATH=/chat/completions


# ---------------- 【端口冲突时调整】宿主机暴露端口 ----------------
# 浏览器访问前端的端口, 默认 https://localhost:8443/mycasemind-cms/
FRONTEND_PORT=8443
# 宿主机访问 mysql 的端口 (仅供本地调试, 业务运行不依赖此值)
MYSQL_PORT=3308


# ---------------- 【可选】镜像版本 ----------------
# latest        : main 分支最新构建
# vX.Y.Z        : 稳定版本号 (推荐生产使用)
# sha-xxxxxxx   : 具体 commit 短 sha
KCASE_TAG=latest


# ---------------- 【一般不改】 ----------------
TZ=Asia/Shanghai
# 后端权限校验开关, 关闭后所有接口免鉴权 (开发用)
AUTHORITY_FLAG=false


# ==========================================================
# 警告: 以下字段切勿修改, 否则启动会失败
# ==========================================================
# 容器内部端口, nginx 反代写死了 backend:8443
BACKEND_INTERNAL_PORT=8443
# sql 初始化脚本里写死的库名
MYSQL_DATABASE=mycase_manager
# mysql 镜像只创建了 root 用户, backend 也用 root 登录
MYSQL_USER=root
